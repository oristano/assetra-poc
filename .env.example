# Copy this file to .env and adjust values before running.

APP_ENV=development
LOG_LEVEL=info
CUSTOMER_ID=12345

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=assetra
POSTGRES_USER=assetra
POSTGRES_PASSWORD=assetra_poc

# Path to the data directory containing aws/ subdirectories (CSV mock files).
# In Docker this is mounted at /data. For local runs use ./data.
DATA_DIR=/data

# Path to the migrations directory.
# In Docker this is mounted at /migrations. For local runs use ./migrations.
MIGRATIONS_DIR=/migrations

# Optional: Steampipe connection (not used by the app directly in this POC).
STEAMPIPE_CONNECTION=postgresql://steampipe:steampipe@steampipe:9193/steampipe
